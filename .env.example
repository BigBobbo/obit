# --- App ---
# Canonical origin of the deployed app (used for QR codes, links in emails, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (DB + Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only. Used by the moderation pipeline, cron jobs and admin actions.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (bot defense) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Claude API (Tier 1 text moderation) ---
ANTHROPIC_API_KEY=

# --- Sightengine (Tier 0 image moderation) ---
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# --- Resend (email) ---
RESEND_API_KEY=
EMAIL_FROM="Memorial Pages <no-reply@example.com>"

# --- Stripe (freemium billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for the single paid tier
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# --- Cron (Vercel cron auth) ---
CRON_SECRET=

# --- Private beta ---
# Comma-separated invite codes required at signup. Leave empty to open signups.
BETA_INVITE_CODES=
